<Grid
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
<Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="10"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="10"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="10"/>
        <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="10"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
    </Grid.ColumnDefinitions>
	<!--TextBlock Grid.Row="1" Grid.ColumnSpan="4" HorizontalAlignment="Left" Text="1985-8-18" FontSize="{StaticResource Font.Size.Header}"/-->
	<TextBlock Grid.Row="1" Grid.ColumnSpan="4" HorizontalAlignment="Left" FontSize="{StaticResource Font.Size.Header}">
		<Run Text="1974 年 8 月 4 日"/>
	</TextBlock>
    <!--TextBlock Grid.Row="1" Grid.ColumnSpan="4" HorizontalAlignment="Right" Text="05:00Z (06:00L)" FontSize="{StaticResource Font.Size.Header}"/-->
    <TextBlock Grid.Row="3" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" Text="發自"/>
    <TextBlock Grid.Row="3" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" Text="南海艦隊司令"/>
    <TextBlock Grid.Row="4" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" Text="致"/>
    <TextBlock Grid.Row="4" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" Text="第 1 水面攻擊部隊司令"/>
    <TextBlock Grid.Row="7" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" Text="主旨"/>
    <TextBlock Grid.Row="7" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" Text="作戰計畫－西沙"/>
	    <!--
	<Image Grid.Row="1" Width="250" Grid.ColumnSpan="4" Grid.RowSpan="6" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Source="{Binding Assets[ts_banner]}"/>
	-->
    <TextBlock Grid.Row="9" Grid.ColumnSpan="4" FontSize="{StaticResource Font.Size.Header}" TextWrapping="Wrap">
		機密
		<LineBreak/>
		<LineBreak/>
		1. 西沙群島的漁民與研究船回報遭越南共和國海軍（RVNN）戰鬥艦艇騷擾。昨日，越南部隊砲擊我方在琛航島升起的旗幟後登陸該島。另有回報指出更多越南海軍兵力與突擊隊正進入群島。這是對我方領土權益的侵犯，司令部已命令南海艦隊立即出航將其驅離。
		<LineBreak/>
		<LineBreak/>
		2. 第 1 水面攻擊部隊將先於第 2 水面部隊進入永樂群島。搜尋並識別當地越南兵力，但除非遭到攻擊，不得開火。
		<LineBreak/>
		<LineBreak/>
		3. 越南兵力包含 1 艘前美國 EDSALL 級驅逐艦（配備 76mm 砲）、2 艘前美國 BARNEGAT 級巡防艦（配備 127mm 砲），以及 1 艘配備輕型機砲的前美國掃雷艦。這些艦艇射程優於我方，建議接近後以我方速射砲壓制。如敵對行動爆發，我方反潛迫擊砲對這些艦艇將極具殺傷力，建議使用。
		<LineBreak/>
		<LineBreak/>
		4. 進入該區，不要惹事，不要首先開火，也不要吃虧。祝好運，獵殺順利。
		<LineBreak/>
		<LineBreak/>
		機密
	</TextBlock>
</Grid>