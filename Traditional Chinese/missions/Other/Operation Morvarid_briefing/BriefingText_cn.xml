<Grid
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
<Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="10"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="10"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="10"/>
        <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="10"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
    </Grid.ColumnDefinitions>
	<!--TextBlock Grid.Row="1" Grid.ColumnSpan="4" HorizontalAlignment="Left" Text="1985-8-18" FontSize="{StaticResource Font.Size.Header}"/-->
	<TextBlock Grid.Row="1" Grid.ColumnSpan="4" HorizontalAlignment="Left" FontSize="{StaticResource Font.Size.Header}">
		1980 年 11 月 28 日
	</TextBlock>
    <!--TextBlock Grid.Row="1" Grid.ColumnSpan="4" HorizontalAlignment="Right" Text="05:00Z (06:00L)" FontSize="{StaticResource Font.Size.Header}"/-->

    <TextBlock Grid.Row="3" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" Text="發自："/>
    <TextBlock Grid.Row="3" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" Text="伊朗伊斯蘭共和國海軍司令"/>
    <TextBlock Grid.Row="4" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" Text="致："/>
    <TextBlock Grid.Row="4" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" Text="第 421 特遣隊司令"/>
    <TextBlock Grid.Row="7" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" Text="主旨："/>
    <TextBlock Grid.Row="7" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" Text="新命令 - 珍珠行動 (عملیات مروارید)"/>
	    <!--
	<Image Grid.Row="1" Width="250" Grid.ColumnSpan="4" Grid.RowSpan="6" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Source="{Binding Assets[ts_banner]}"/>
	-->
    <TextBlock Grid.Row="9" Grid.ColumnSpan="4" FontSize="{StaticResource Font.Size.Header}" TextWrapping="Wrap">
		機密
		<LineBreak/>
		<LineBreak/>
		1. 伊拉克部隊摧毀了我方位於阿巴丹的煉油廠，最高指揮部已下令發動報復性打擊。我方將摧毀 Khor al-Amaya 與 Mina al-Bakr 離岸石油碼頭。失去這些戰略石油碼頭將嚴重削弱伊拉克出口石油的能力。司令部評估，此次攻擊將引出伊拉克海軍，使我軍得以將其摧毀。
		<LineBreak/>
		<LineBreak/>
		2. 今夜，第 421 特遣隊將派遣陸戰隊登上石油碼頭，安置爆破裝藥後由直升機撤離。第 421 特遣隊艦艇將留在外海封鎖法奧與烏姆卡斯爾。JOSHAN 與 PAYKAN 指派參與本行動。
		<LineBreak/>
		<LineBreak/>
		3. 最新評估顯示法奧有 4 艘 P-6 魚雷艇，烏姆卡斯爾有 5 艘 OSA 或 OSA II 級飛彈艇。烏姆卡斯爾另有一艘 POLNOCNY 級兩棲艦，可能出航企圖奪回石油碼頭。
		<LineBreak/>
		<LineBreak/>
		4. 一架伊朗空軍 Tomcat 攔截機將撥交你方作為空中雷達平台。配備 Maverick 飛彈的 Phantom 也將自布什爾出動支援你方。誘使敵軍出海，然後摧毀遭遇的所有兵力。祝好運。
		<LineBreak/>
		<LineBreak/>
		機密
	  </TextBlock>
</Grid>