<Grid
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
<Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="10"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="10"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="10"/>
        <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="10"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
    </Grid.ColumnDefinitions>
    <!--TextBlock Grid.Row="1" Grid.ColumnSpan="4" HorizontalAlignment="Left" Text="1985-8-18" FontSize="{StaticResource Font.Size.Header}"/-->
    <TextBlock Grid.Row="1" Grid.ColumnSpan="4" HorizontalAlignment="Left" FontSize="{StaticResource Font.Size.Header}">
        1985年8月18日
    </TextBlock>
    <!--TextBlock Grid.Row="1" Grid.ColumnSpan="4" HorizontalAlignment="Right" Text="05:00Z (06:00L)" FontSize="{StaticResource Font.Size.Header}"/-->

    <TextBlock Grid.Row="3" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" Text="發件："/>
    <TextBlock Grid.Row="3" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" Text="太平洋艦隊總司令"/>
    <TextBlock Grid.Row="4" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" Text="收件："/>
    <TextBlock Grid.Row="4" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" Text="貝里琉號兩棲戒備群/第78特遣艦隊指揮官"/>
    <TextBlock Grid.Row="7" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" Text="主題："/>
    <TextBlock Grid.Row="7" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" Text="行動計划——南方盾牌"/>
        <!--
    <Image Grid.Row="1" Width="250" Grid.ColumnSpan="4" Grid.RowSpan="6" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Source="{Binding Assets[ts_banner]}"/>
    -->
    <TextBlock Grid.Row="9" Grid.ColumnSpan="4" FontSize="{StaticResource Font.Size.Header}" TextWrapping="Wrap">
        緊急——機密
        <LineBreak/>
        <LineBreak/>
        1.（機密）態勢：華約軍隊正在嘗試推翻馬達加斯加政府並佔領此島嶼以支援其在莫桑比克和印度洋的行動。古巴特種部隊的突襲已將馬達加斯加政府斩首，使其軍隊陷入混乱。北約及盟友的兵力捉襟見肘，但馬達加斯加是戰略要地，絕不能落入共產主義陣營之手。衝突爆發後，對南非的制裁和禁運已被解除，其久經沙場的部隊如今已成為我們在此區域內的重要盟友，可供我們調遣。
        <LineBreak/>
        <LineBreak/>
        2.（機密）任務：貝里琉號兩棲戒備群將部署海軍陸戰隊第17遠征隊以增援塔那那利佛的抵抗力量。第78特遣艦隊摧毀遭遇的任何敵方海空部隊。
        <LineBreak/>
        <LineBreak/>
        3.（機密）執行：貝里琉號的空中單位將對塔那那利佛的美軍和抵抗力量進行空中補給並消滅遭遇的敵軍。通往塔那那利佛的空中走廊遍布防空火力，需要貝里琉號出動攻擊機進行壓制。南非空軍的幻影F1戰鬥機將提供戰鬥空中巡邏。
        <LineBreak/>
        <LineBreak/>
        4.（機密）友軍：南非國防軍單位將向第78特遣艦隊提供支援，第3中隊的幻影F1可進行戰鬥空中巡邏，南非海軍潛艦約翰娜·范德梅維號將掩護貝里琉號兩棲戒備群向北航行。梅里爾號將加入你的部隊，這艘驅逐艦搭載了新型的戰斧對地攻擊飛彈，並且包含所有已知敵方陣地瞄準數據的磁帶也已被空運至艦上。
        <LineBreak/>
        <LineBreak/>
        5.（機密）敵方部署：古巴空軍單位在附近海域活動，可能嘗試攻擊貝里琉號兩棲戒備群及友軍。我們已發現東德偵察船在馬達加斯加東北海域活動，應盡可能將其摧毀。
        <LineBreak/>
        <LineBreak/>
		6.（機密）備注：此次行動是防止關鍵戰略盟友被華約控制的第一步。祝你好運，獵殺愉快。
        <LineBreak/>
        <LineBreak/>
        機密
        <LineBreak/>
        未經收件人許可不得解密
      </TextBlock>
</Grid>