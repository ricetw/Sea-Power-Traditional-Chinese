<Grid
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
<Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="10"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="10"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="10"/>
        <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="10"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
    </Grid.ColumnDefinitions>
	<!--TextBlock Grid.Row="1" Grid.ColumnSpan="4" HorizontalAlignment="Left" Text="1985-8-18" FontSize="{StaticResource Font.Size.Header}"/-->
	<TextBlock Grid.Row="1" Grid.ColumnSpan="4" HorizontalAlignment="Left" FontSize="{StaticResource Font.Size.Header}">
		1983年10月23日
	</TextBlock>
    <!--TextBlock Grid.Row="1" Grid.ColumnSpan="4" HorizontalAlignment="Right" Text="05:00Z (06:00L)" FontSize="{StaticResource Font.Size.Header}"/-->

    <TextBlock Grid.Row="3" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" Text="發件："/>
    <TextBlock Grid.Row="3" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" Text="第二艦隊司令"/>
    <TextBlock Grid.Row="4" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" Text="收件："/>
    <TextBlock Grid.Row="4" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" Text="卡隆號驅逐艦"/>
    <TextBlock Grid.Row="7" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" Text="主題："/>
    <TextBlock Grid.Row="7" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" Text="片段命令01——緊急狂暴行動"/>
	    <!--
	<Image Grid.Row="1" Width="250" Grid.ColumnSpan="4" Grid.RowSpan="6" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Source="{Binding Assets[ts_banner]}"/>
	-->
    <TextBlock Grid.Row="9" Grid.ColumnSpan="4" FontSize="{StaticResource Font.Size.Header}" TextWrapping="Wrap">
		緊急——機密
		<LineBreak/>
		<LineBreak/>		1.（機密）態勢：美國情報機构認為古巴和蘇聯軍隊正在安的列斯群島南部的格林納達建造一座軍用機場。總統將在不久後授權進行緊急狂暴行動，其目的是保護格林納達的美國公民，建立民主政府，消除古巴和蘇聯對此島嶼的影響。我們正在建立第120聯合特遣艦隊以執行此次行動。
		<LineBreak/>
		<LineBreak/>		2.（機密）任務：美國海陸空三軍將對島嶼進行協同攻擊，營救所有美國公民，摧毀抵抗之敵。
		<LineBreak/>
		<LineBreak/>		3.（機密）執行：卡隆號將負責為岸上部隊提供海軍砲火支援。此命令立即生效，脫離獨立號戰鬥群，以最快速度向南前進。穆斯布魯格號會在10月21日加入你們。在格林納達12海里外的海域使用外側系統收集情報，之後等待進一步命令。
		<LineBreak/>
		<LineBreak/>		4.（機密）敵方作戰序列：我們怀疑格林納達人民革命軍使用蘇聯提供的裝甲車和ZU-23防空砲。岸上的古巴顾問團也裝備了轻型裝甲車，有跡象表明此地區存在641型潛艦。
		<LineBreak/>
		<LineBreak/>		5.（機密）友方作戰序列：獨立號戰鬥群將在格林納達西北方就位。關島號及其所屬的地中海兩棲戒備群1-84將在北方就位。來自獨立號的攻擊機小隊和來自關島號的眼鏡蛇直升機將為岸上的部隊提供空中支援。
		<LineBreak/>
		<LineBreak/>		6.（機密）備注：此次行動將確保美國公民的安全並防止蘇聯在加勒比海建立另一個基地。祝你好運，狩獵愉快。
		<LineBreak/>
		<LineBreak/>
		機密
		<LineBreak/>		未經收件人許可不得解密
	  </TextBlock>
</Grid>