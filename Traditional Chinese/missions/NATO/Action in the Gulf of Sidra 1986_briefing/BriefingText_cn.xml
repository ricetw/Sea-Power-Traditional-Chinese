<Grid
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
<Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="10"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="10"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="10"/>
        <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="10"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
    </Grid.ColumnDefinitions>
	<!--<TextBlock Grid.Row="1" Grid.Column="4" HorizontalAlignment="Left" FontSize="{StaticResource Font.Size.Header}">
		DEPARTMENT OF DEFENSE
		<LineBreak/>
		JCS MESSAGE CENTER
	</TextBlock>-->
	<TextBlock Grid.Row="1" Grid.ColumnSpan="4" HorizontalAlignment="Left" FontSize="{StaticResource Font.Size.Header}">
		緊急
		<LineBreak/>
		1986年3月23日0017Z時
	</TextBlock>
    <!--TextBlock Grid.Row="1" Grid.ColumnSpan="4" HorizontalAlignment="Right" Text="05:00Z (06:00L)" FontSize="{StaticResource Font.Size.Header}"/-->

    <TextBlock Grid.Row="3" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" Text="發件："/>
    <TextBlock Grid.Row="3" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" Text="第六艦隊司令"/>
    <TextBlock Grid.Row="4" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" Text="收件："/>
    <TextBlock Grid.Row="4" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" Text="第60特遣艦隊指揮官"/>
	<TextBlock Grid.Row="5" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" Text="抄送："/>
    <TextBlock Grid.Row="5" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}">
		華盛頓特區參謀長聯席會議//參謀長聯席會議主席//<LineBreak/>
		德國法伊英根美國歐洲司令部總司令<LineBreak/>
		弗吉尼亞州諾福克美國大西洋司令部總司令<LineBreak/>
		華盛頓特區國防情報局
	</TextBlock>
    <TextBlock Grid.Row="7" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" Text="主題："/>
    <TextBlock Grid.Row="7" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" Text="行動命令——草原烈火行動"/>
	    <!--
	<Image Grid.Row="1" Width="250" Grid.ColumnSpan="4" Grid.RowSpan="6" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Source="{Binding Assets[ts_banner]}"/>
	-->
    <TextBlock Grid.Row="9" Grid.ColumnSpan="4" FontSize="{StaticResource Font.Size.Header}" TextWrapping="Wrap">
		絕密
		<LineBreak/>
		<LineBreak/>
		1.（絕密）此命令為國防部長授權並指示的命令。
		<LineBreak/>
		<LineBreak/>
		2.（絕密）態勢：由於利比亞軍隊對我方在北緯32度30分以南的錫德拉灣海域執行的航行自由行動發起了敵對行為，參謀長聯席會議已授權啟動草原烈火行動。
		<LineBreak/>
		<LineBreak/>
		3.（絕密）任務：收到此命令後，第60特遣艦隊對草原烈火行動計划中的優先目標進行打擊。
		<LineBreak/>
		<LineBreak/>
		4.（絕密）執行：薩拉托加號航母（第60.2特遣大隊）的航空聯隊摧毀位於蘇爾特的利比亞S-200面對空飛彈陣地，並為提康德羅加號水面行動群提供戰鬥空中巡邏和水面戰鬥空中巡邏。 提康德羅加號水面行動群（第60.5特遣大隊）開始通過錫德拉灣，開火摧毀反擊的利比亞海軍單位。
		<LineBreak/>
		<LineBreak/>
		5.（絕密）提示：從的黎波里起飛的利比亞空軍可能出動支援海軍部隊。
		<LineBreak/>
		<LineBreak/>
		6.（絕密）交戰規則保持不變。消滅所有敵對力量。祝你好運，獵殺愉快。
		<LineBreak/>
		<LineBreak/>
		絕密
		<LineBreak/>
		解密：由原始發布機构决定
		</TextBlock>

</Grid>