<Viewbox Margin="20" HorizontalAlignment="Center" VerticalAlignment="Center"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="clr-namespace:SeapowerUI">
	<Canvas Width="1095" Height="662">
        <Image Source="{Binding Assets[DenmarkStrait_Close]}"/>
		<!-- Small Map -->
        <Border Canvas.Right="10" Canvas.Top="10" BorderThickness="5" BorderBrush="White">
            <Grid>
                <Image Stretch="Uniform" Source="{Binding Assets[AtlanticFar]}" Width="250"/>
                <Border BorderThickness="2" HorizontalAlignment="Left" VerticalAlignment="Bottom" Width="30" Height="20" Margin="140,0,0,140" BorderBrush="{StaticResource Brush.Border.FocusAccent}"/>
            </Grid>
        </Border>

		<!-- Map Labels -->
		<TextBlock Foreground="Black" Text="Iceland" HorizontalAlignment="Center" FontSize="16" FontWeight="Bold" Canvas.Left="700" Canvas.Top="600"/>
		<TextBlock Foreground="Black" Text="Greenland" HorizontalAlignment="Center" FontSize="16" FontWeight="Bold" Canvas.Left="50" Canvas.Top="50"/>
		<TextBlock Foreground="SteelBlue" Text="Denmark Strait" HorizontalAlignment="Center" FontSize="16" FontWeight="Bold" Canvas.Left="150" Canvas.Top="450"/>
		
		<!-- NATO Submarine (?) -->
		<StackPanel Orientation="Vertical" Canvas.Left="300" Canvas.Top="400">
			<TextBlock Foreground="Red" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="Los Angeles class SSN"/>
            </TextBlock>
			<Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}" Stroke="{StaticResource NTDS.HostileColour}" Data="{StaticResource NTDS.Enemy.Submarine}"/>
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325" Stroke="{StaticResource NTDS.HostileColour}"/>
            </Canvas>
        </StackPanel>
		
		<!-- K-316 -->
		<StackPanel Orientation="Vertical" Canvas.Left="690" Canvas.Top="100">
			<TextBlock Foreground="Blue" TextAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                <Run Text="K-316"/>
            </TextBlock>
			<Canvas Width="22.5" Height="22.5" HorizontalAlignment="Center">
                <Path StrokeThickness="{DynamicResource ContactIconThickness}" Stroke="{StaticResource NTDS.FriendColour}" Data="{StaticResource NTDS.Allied.Submarine}"/>
                <Ellipse Canvas.Left="10" Canvas.Top="10" Width="3" Height="3" StrokeThickness="1.325" Stroke="{StaticResource NTDS.FriendColour}"/>
            </Canvas>
        </StackPanel>

		<!-- Arrows -->
		<!-- Tool for making paths: https://yqnn.github.io/svg-path-editor/ -->
        <Path Canvas.Left="490" Canvas.Top="340" Data="M 0 -7 L 10 10 L 4 10 L 4 60 L -4 60 L -4 10 L -10 10 Z" Fill="{StaticResource NTDS.HostileColour}">
            <Path.RenderTransform>
                <RotateTransform Angle="50"/>
            </Path.RenderTransform>
        </Path>
		
		<Path Canvas.Left="625" Canvas.Top="200" Data="M 0 -7 L 10 10 L 4 10 L 4 60 L -4 60 L -4 10 L -10 10 Z" Fill="{StaticResource NTDS.FriendColour}">
            <Path.RenderTransform>
                <RotateTransform Angle="230"/>
            </Path.RenderTransform>
        </Path>
	</Canvas>
</Viewbox>