<Grid
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
<Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="10"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="10"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="10"/>
        <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="10"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
    </Grid.ColumnDefinitions>
	<!--TextBlock Grid.Row="1" Grid.ColumnSpan="4" HorizontalAlignment="Left" Text="1985-8-18" FontSize="{StaticResource Font.Size.Header}"/-->
	<TextBlock Grid.Row="1" Grid.ColumnSpan="4" HorizontalAlignment="Left" FontSize="{StaticResource Font.Size.Header}">
		29JAN1985
	</TextBlock>
    <!--TextBlock Grid.Row="1" Grid.ColumnSpan="4" HorizontalAlignment="Right" Text="05:00Z (06:00L)" FontSize="{StaticResource Font.Size.Header}"/-->

    <TextBlock Grid.Row="3" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" Text="FM"/>
    <TextBlock Grid.Row="3" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" Text="COMLANTFLT"/>
    <TextBlock Grid.Row="4" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" Text="TO"/>
    <TextBlock Grid.Row="4" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" Text="CMDR USS PARGO SSN-650"/>
    <TextBlock Grid.Row="7" Grid.Column="0" FontSize="{StaticResource Font.Size.Header}" Text="SUBJ"/>
    <TextBlock Grid.Row="7" Grid.Column="2" FontSize="{StaticResource Font.Size.Header}" Text="FRAGORD 01 - URGENT RETASKING"/>
	    <!--
	<Image Grid.Row="1" Width="250" Grid.ColumnSpan="4" Grid.RowSpan="6" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Source="{Binding Assets[ts_banner]}"/>
	-->
    <TextBlock Grid.Row="9" Grid.ColumnSpan="4" FontSize="{StaticResource Font.Size.Header}" TextWrapping="Wrap">
		FLASH - TOP SECRET
		<LineBreak/>
		<LineBreak/>
		1. (TS) NATIONAL TECHNICAL INTELLIGENCE SOURCES INDICATE USSR CARRIER GROUP CENTERED ON KIEV MOVING SOUTHWEST TOWARDS DENMARK STRAIT.
		<LineBreak/>
		<LineBreak/>
		2. (TS) LAST SATELLITE PASS 28JAN SHOWS GROUP ON COURSE 230 SPEED 20 APPROX 150NM NORTH OF JAN MAYEN.
		<LineBreak/>
		<LineBreak/>
		3. (S) PROCEED NORTH FROM YOUR ASSIGNED PATROL SECTOR AT BEST SPEED, THEN INTERCEPT AND DESTROY THE KIEV BATTLE GROUP.
		<LineBreak/>
		<LineBreak/>
		4. (S) ENEMY FORCE IS COMPRISED OF KIEV, 1 X KRESTA CG, 2 X KRIVAK FFG, 1 X UDALOY DDG.
		<LineBreak/>
		<LineBreak/>
		5. (S) KIEV IS PRIMARY TARGET. REPORT LOCATION OF SINKING, THEN AWAIT FURTHER ORDERS. GOOD LUCK AND GOOD HUNTING.
		<LineBreak/>
		<LineBreak/>
		SECRET
		<LineBreak/>
		DO NOT DECLASSIFY WITHOUT APPROVAL OF ADDRESSEE
	  </TextBlock>
</Grid>